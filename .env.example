# Server Configuration

# Server
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s

# Database
# For local development with Docker Compose: use localhost with sslmode=disable
# For Neon PostgreSQL 17 (free tier): get connection string from https://neon.tech
# Note: Neon requires SSL (sslmode=require), self-hosted PostgreSQL may not
DB_HOST=localhost
DB_PORT=5432
DB_USER=enclavr
DB_PASSWORD=changeme
DB_NAME=enclavr
DB_SSLMODE=disable

# Authentication
JWT_SECRET=changeme-change-in-production
JWT_EXPIRATION=24h
REFRESH_EXPIRATION=168h

# Encryption Key (32 bytes minimum, used for encrypting 2FA secrets)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# OIDC (Optional)
OIDC_ENABLED=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Voice (WebRTC)
STUN_SERVER=stun:stun.l.google.com:19302
TURN_SERVER=
TURN_USER=
TURN_PASS=

# Sentry Error Tracking (optional - leave empty to disable)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Admin User Configuration
# Set ADMIN_PASSWORD to create a default admin user on first startup
# If FIRST_USER_IS_ADMIN=true, the first user registered via API will become admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_EMAIL=admin@enclavr.local
FIRST_USER_IS_ADMIN=true
